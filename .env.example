# --- xAI Grok Voice ---
XAI_API_KEY=
GROK_MODEL=grok-voice-latest
GROK_VOICE=eve
# Rate PCM16 declare a Grok. 8000 = aucun resampling (a tester EN PREMIER). Sinon 24000.
GROK_RATE=8000

# --- Agent de reception ---
AGENT_LANG=fr
AGENT_NAME=Dany
BUSINESS_NAME=Motralec
BUSINESS_DESC=distribution de pompes et moteurs electriques
# Optionnel : surcharger toute l'instruction de l'agent
# RECEPTION_PROMPT=

# --- Recap (n8n) ---
N8N_RECAP_URL=

# PORT est injecte par Railway en prod (8080 en local par defaut)
